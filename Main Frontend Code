<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Maison Doré — Artisanal Bakery</title>
<script src="https://cdn.tailwindcss.com"></script>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --wood-darkest: #1a0f08;
    --wood-dark: #2a1810;
    --wood-mid: #3d2418;
    --wood-light: #5c3a25;
    --gold: #d4a85a;
    --gold-light: #f0c878;
    --gold-deep: #b8893d;
    --cream: #f5e6c8;
  }

  * { box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    margin: 0;
    font-family: 'Inter', sans-serif;
    background: var(--wood-darkest);
    color: var(--cream);
    overflow-x: hidden;
  }

  .serif { font-family: 'Cormorant Garamond', serif; }

  /* Wood texture background */
  .wood-bg {
    background:
      radial-gradient(ellipse at top, rgba(212, 168, 90, 0.08) 0%, transparent 60%),
      radial-gradient(ellipse at bottom right, rgba(212, 168, 90, 0.06) 0%, transparent 50%),
      linear-gradient(180deg, #1a0f08 0%, #2a1810 50%, #1a0f08 100%);
    position: relative;
  }

  .wood-bg::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      repeating-linear-gradient(90deg,
        transparent 0px,
        rgba(0,0,0,0.15) 1px,
        transparent 2px,
        transparent 80px),
      repeating-linear-gradient(0deg,
        transparent 0px,
        rgba(212, 168, 90, 0.02) 1px,
        transparent 3px);
    pointer-events: none;
    opacity: 0.6;
  }

  /* Gold gradient text */
  .gold-text {
    background: linear-gradient(135deg, #f0c878 0%, #d4a85a 40%, #b8893d 70%, #f0c878 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    background-size: 200% 200%;
    animation: shimmer 8s ease infinite;
  }

  @keyframes shimmer {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  /* Header */
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    transition: all 0.4s ease;
    backdrop-filter: blur(0px);
  }

  .header.scrolled {
    backdrop-filter: blur(20px);
    background: rgba(26, 15, 8, 0.85);
    border-bottom: 1px solid rgba(212, 168, 90, 0.15);
  }

  /* Logo */
  .logo-mark {
    width: 44px;
    height: 44px;
    border: 1.5px solid var(--gold);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .logo-mark::before {
    content: '';
    position: absolute;
    inset: 4px;
    border: 1px solid rgba(212, 168, 90, 0.4);
    border-radius: 50%;
  }

  /* Hero bread illustration using CSS / SVG */
  .hero-image-wrap {
    position: relative;
    filter: drop-shadow(0 40px 60px rgba(0,0,0,0.6));
  }

  .hero-image-wrap::after {
    content: '';
    position: absolute;
    bottom: -10%;
    left: 10%;
    right: 10%;
    height: 60px;
    background: radial-gradient(ellipse, rgba(0,0,0,0.5) 0%, transparent 70%);
    filter: blur(20px);
    z-index: -1;
  }

  /* Spotlight */
  .spotlight {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 50% at 70% 40%, rgba(240, 200, 120, 0.18) 0%, transparent 70%);
    pointer-events: none;
  }

  /* Golden button */
  .btn-gold {
    position: relative;
    background: linear-gradient(135deg, #d4a85a 0%, #b8893d 100%);
    color: #1a0f08;
    font-weight: 600;
    letter-spacing: 0.1em;
    border-radius: 999px;
    padding: 1.1rem 2.6rem;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow:
      0 0 0 1px rgba(240, 200, 120, 0.3),
      0 10px 30px rgba(212, 168, 90, 0.3),
      0 0 60px rgba(212, 168, 90, 0.15);
    overflow: hidden;
  }

  .btn-gold::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent);
    transition: left 0.6s ease;
  }

  .btn-gold:hover::before { left: 100%; }

  .btn-gold:hover {
    transform: translateY(-3px);
    box-shadow:
      0 0 0 1px rgba(240, 200, 120, 0.5),
      0 20px 50px rgba(212, 168, 90, 0.5),
      0 0 100px rgba(212, 168, 90, 0.3);
  }

  .btn-ghost {
    border: 1px solid rgba(212, 168, 90, 0.4);
    color: var(--gold-light);
    border-radius: 999px;
    padding: 1.1rem 2.6rem;
    transition: all 0.3s ease;
    letter-spacing: 0.1em;
  }

  .btn-ghost:hover {
    background: rgba(212, 168, 90, 0.1);
    border-color: var(--gold);
  }

  /* Glow CTA at bottom */
  .glow-cta {
    background: linear-gradient(135deg, #f0c878 0%, #d4a85a 50%, #b8893d 100%);
    color: #1a0f08;
    font-weight: 700;
    letter-spacing: 0.2em;
    padding: 1.4rem 4rem;
    border-radius: 999px;
    position: relative;
    box-shadow:
      0 0 0 1px rgba(240, 200, 120, 0.4),
      0 0 40px rgba(212, 168, 90, 0.4),
      0 0 80px rgba(212, 168, 90, 0.3),
      0 20px 50px rgba(0, 0, 0, 0.5);
    transition: all 0.4s ease;
    animation: pulseGlow 3s ease-in-out infinite;
  }

  @keyframes pulseGlow {
    0%, 100% {
      box-shadow:
        0 0 0 1px rgba(240, 200, 120, 0.4),
        0 0 40px rgba(212, 168, 90, 0.4),
        0 0 80px rgba(212, 168, 90, 0.3),
        0 20px 50px rgba(0, 0, 0, 0.5);
    }
    50% {
      box-shadow:
        0 0 0 1px rgba(240, 200, 120, 0.6),
        0 0 60px rgba(212, 168, 90, 0.6),
        0 0 120px rgba(212, 168, 90, 0.4),
        0 20px 50px rgba(0, 0, 0, 0.5);
    }
  }

  .glow-cta:hover {
    transform: translateY(-4px) scale(1.02);
  }

  /* Card */
  .product-card {
    background: linear-gradient(180deg, rgba(61, 36, 24, 0.4) 0%, rgba(26, 15, 8, 0.6) 100%);
    border: 1px solid rgba(212, 168, 90, 0.15);
    border-radius: 24px;
    overflow: hidden;
    transition: all 0.5s ease;
    backdrop-filter: blur(10px);
  }

  .product-card:hover {
    transform: translateY(-8px);
    border-color: rgba(212, 168, 90, 0.4);
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.5), 0 0 40px rgba(212, 168, 90, 0.1);
  }

  .product-img {
    height: 280px;
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, #2a1810 0%, #1a0f08 100%);
  }

  /* Divider */
  .divider {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .divider .line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
  }

  /* Reveal animation */
  .reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 1s ease, transform 1s ease;
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Float animation */
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-15px); }
  }

  .float-anim { animation: float 6s ease-in-out infinite; }

  /* Steam */
  .steam {
    position: absolute;
    bottom: 100%;
    width: 8px;
    height: 60px;
    background: linear-gradient(180deg, rgba(255,255,255,0.3), transparent);
    border-radius: 50%;
    filter: blur(8px);
    animation: rise 4s ease-in infinite;
    opacity: 0;
  }

  @keyframes rise {
    0% { opacity: 0; transform: translateY(0) scale(1); }
    20% { opacity: 0.6; }
    100% { opacity: 0; transform: translateY(-80px) scale(2); }
  }

  /* Hero image as photographic gradient illustration */
  .hero-bread-scene {
    width: 100%;
    aspect-ratio: 1/1;
    max-width: 600px;
    position: relative;
    margin: 0 auto;
  }
</style>
</head>
